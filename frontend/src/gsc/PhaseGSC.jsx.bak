/**
 * Phase GSC — Google Search Console Engine
 * Sits between PhaseBI (Intel) and Phase 2 (Generate)
 *
 * 3 tabs:
 *   1. Connect & Sync   — OAuth setup, pull GSC data, raw metrics table
 *   2. Intelligence     — Pillar matching, intent classification, scoring
 *   3. Strategy         — Top 100, opportunities, tree view
 */
import React, { useState, useEffect, useCallback } from "react"
import useKw2Store from "../kw2/store"
import * as gscApi from "./api"
import KeywordGraph from "./KeywordGraph"

/* ── Shared colours / helpers ─────────────────────────────────────────────── */

const INTENT_COLOR = {
  purchase:      { bg: "#dcfce7", fg: "#166534", icon: "💰" },
  wholesale:     { bg: "#ede9fe", fg: "#5b21b6", icon: "🏭" },
  commercial:    { bg: "#fef9c3", fg: "#854d0e", icon: "⭐" },
  informational: { bg: "#f3f4f6", fg: "#374151", icon: "📚" },
  navigational:  { bg: "#dbeafe", fg: "#1e40af", icon: "🔗" },
}

function IntentBadge({ intent }) {
  const c = INTENT_COLOR[intent] || INTENT_COLOR.informational
  return (
    <span style={{
      display: "inline-flex", alignItems: "center", gap: 3,
      padding: "1px 8px", borderRadius: 10, fontSize: 10, fontWeight: 600,
      background: c.bg, color: c.fg,
    }}>
      {c.icon} {intent}
    </span>
  )
}

function MetricCard({ label, value, sub, color = "#3b82f6" }) {
  return (
    <div style={{
      padding: "10px 16px", borderRadius: 8, border: "1px solid #e5e7eb",
      background: "#fff", minWidth: 100, flex: "1 1 100px",
    }}>
      <div style={{ fontSize: 20, fontWeight: 800, color }}>{value ?? "—"}</div>
      <div style={{ fontSize: 11, fontWeight: 600, color: "#374151" }}>{label}</div>
      {sub && <div style={{ fontSize: 10, color: "#9ca3af" }}>{sub}</div>}
    </div>
  )
}

function Btn({ onClick, disabled, children, color = "blue", size = "sm" }) {
  const C = { blue: "#3b82f6", green: "#10b981", red: "#ef4444", gray: "#6b7280" }
  return (
    <button
      onClick={onClick} disabled={disabled}
      style={{
        padding: size === "sm" ? "5px 14px" : "8px 20px",
        borderRadius: 6, border: "none", cursor: disabled ? "not-allowed" : "pointer",
        background: disabled ? "#d1d5db" : (C[color] || C.blue),
        color: "#fff", fontWeight: 600, fontSize: size === "sm" ? 12 : 13,
        opacity: disabled ? 0.7 : 1,
      }}
    >{children}</button>
  )
}

function SectionTitle({ children }) {
  return (
    <div style={{
      fontSize: 13, fontWeight: 700, color: "#1e40af",
      borderBottom: "2px solid #dbeafe", paddingBottom: 5, marginBottom: 12,
    }}>{children}</div>
  )
}

/* ── Tab 0: Project Intelligence (AI Config Generation) ─────────────────── */

function Tab0Intelligence({ projectId, onReady }) {
  const { profile } = useKw2Store()
  const [config, setConfig] = useState(null)
  const [loading, setLoading] = useState(false)
  const [saving, setSaving] = useState(false)
  const [error, setError] = useState(null)
  const [success, setSuccess] = useState(null)

  // Form state
  const [bizDesc, setBizDesc] = useState("")
  const [goal, setGoal] = useState("sales")
  const [audience, setAudience] = useState("")
  const [seedsRaw, setSeedsRaw] = useState("")

  // On mount: load stored config + pre-fill from kw2 profile
  useEffect(() => {
    gscApi.getConfig(projectId)
      .then(r => { if (r?.config) setConfig(r.config) })
      .catch(() => {})
    // Pre-fill from business profile if available
    if (profile) {
      if (profile.business_description || profile.about) {
        setBizDesc(profile.business_description || profile.about || "")
      }
      if (profile.target_audience) setAudience(profile.target_audience)
      const pils = profile.pillar_keywords || profile.pillars || []
      if (pils.length) setSeedsRaw(pils.join(", "))
    }
  }, [projectId, profile])

  const handleGenerate = useCallback(async () => {
    if (!bizDesc.trim()) { setError("Business description is required"); return }
    setLoading(true); setError(null); setSuccess(null)
    try {
      const seeds = seedsRaw
        .split(/[,\n]/)
        .map(s => s.trim())
        .filter(Boolean)
      const r = await gscApi.generateConfig(projectId, {
        business_description: bizDesc,
        goal,
        seed_keywords: seeds,
        target_audience: audience,
      })
      setConfig(r.config)
      setSuccess(`✓ AI config generated: ${r.config.pillars?.length || 0} pillars, ${r.config.purchase_intent_keywords?.length || 0} intent signals`)
    } catch (e) { setError(e.message) }
    setLoading(false)
  }, [projectId, bizDesc, goal, audience, seedsRaw])

  const handleSaveManual = useCallback(async () => {
    if (!config) return
    setSaving(true)
    try {
      const r = await gscApi.updateConfig(projectId, config)
      setConfig(r.config)
      setSuccess("✓ Config saved")
    } catch (e) { setError(e.message) }
    setSaving(false)
  }, [projectId, config])

  const updatePillars = (val) => {
    const pillars = val.split(/[,\n]/).map(s => s.trim()).filter(Boolean)
    setConfig(c => ({ ...c, pillars }))
  }
  const updateIntentKws = (val) => {
    const kws = val.split(/[,\n]/).map(s => s.trim()).filter(Boolean)
    setConfig(c => ({ ...c, purchase_intent_keywords: kws }))
  }
  const updateAngles = (val) => {
    const angles = val.split(/[,\n]/).map(s => s.trim()).filter(Boolean)
    setConfig(c => ({ ...c, supporting_angles: angles }))
  }

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
      {/* What this step does */}
      <div style={{
        padding: "10px 14px", borderRadius: 8,
        background: "linear-gradient(135deg,#eff6ff,#f0fdf4)",
        border: "1px solid #bfdbfe", fontSize: 12,
      }}>
        <div style={{ fontWeight: 700, marginBottom: 4, color: "#1e40af" }}>
          🧠 Step 1 — AI Project Understanding
        </div>
        <div style={{ color: "#374151", lineHeight: 1.6 }}>
          Describe your business. The AI generates a structured <strong>project config</strong>:
          pillars, purchase-intent signals, supporting angles, and synonyms.
          This config drives all downstream GSC filtering and scoring.
        </div>
        <div style={{ marginTop: 6, padding: "6px 10px", borderRadius: 6, background: "#fff", fontSize: 11, color: "#6b7280" }}>
          <strong>Flow:</strong> User Input → AI Config → GSC Data Pull (1 call) → Config-driven Processing → Top 100 per Pillar
        </div>
      </div>

      {/* Input form */}
      <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
        <SectionTitle>Business Description</SectionTitle>
        <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
          <div style={{ flex: "1 1 280px" }}>
            <label style={{ fontSize: 11, fontWeight: 600, color: "#374151", display: "block", marginBottom: 4 }}>
              Describe your business *
            </label>
            <textarea
              value={bizDesc}
              onChange={e => setBizDesc(e.target.value)}
              rows={4}
              placeholder="e.g. Export of premium spices from India. Focus: Cardamom, Turmeric, Black Pepper. Target: global wholesale buyers and importers."
              style={{ width: "100%", padding: "8px 10px", borderRadius: 6, border: "1px solid #d1d5db",
                fontSize: 12, resize: "vertical", boxSizing: "border-box", fontFamily: "inherit" }}
            />
          </div>
          <div style={{ display: "flex", flexDirection: "column", gap: 8, flex: "0 0 210px" }}>
            <div>
              <label style={{ fontSize: 11, fontWeight: 600, color: "#374151", display: "block", marginBottom: 4 }}>
                Primary Goal
              </label>
              <select value={goal} onChange={e => setGoal(e.target.value)}
                style={{ width: "100%", padding: "6px 8px", borderRadius: 5, border: "1px solid #d1d5db", fontSize: 12 }}>
                <option value="sales">💰 Sales / Conversions</option>
                <option value="leads">📋 Lead Generation</option>
                <option value="traffic">📈 Organic Traffic</option>
              </select>
            </div>
            <div>
              <label style={{ fontSize: 11, fontWeight: 600, color: "#374151", display: "block", marginBottom: 4 }}>
                Target Audience (optional)
              </label>
              <input
                value={audience}
                onChange={e => setAudience(e.target.value)}
                placeholder="e.g. importers, wholesalers, B2B buyers"
                style={{ width: "100%", padding: "6px 8px", borderRadius: 5, border: "1px solid #d1d5db",
                  fontSize: 12, boxSizing: "border-box" }}
              />
            </div>
            <div>
              <label style={{ fontSize: 11, fontWeight: 600, color: "#374151", display: "block", marginBottom: 4 }}>
                Seed Keywords (comma separated)
              </label>
              <input
                value={seedsRaw}
                onChange={e => setSeedsRaw(e.target.value)}
                placeholder="cardamom, turmeric, black pepper"
                style={{ width: "100%", padding: "6px 8px", borderRadius: 5, border: "1px solid #d1d5db",
                  fontSize: 12, boxSizing: "border-box" }}
              />
            </div>
          </div>
        </div>
        <div>
          <Btn onClick={handleGenerate} disabled={loading || !bizDesc.trim()} color="blue" size="md">
            {loading ? "⟳ AI is analyzing your business..." : "🧠 Generate AI Project Config"}
          </Btn>
        </div>
      </div>

      {error && (
        <div style={{ padding: 10, borderRadius: 6, background: "#fee2e2", color: "#dc2626", fontSize: 12 }}>{error}</div>
      )}
      {success && (
        <div style={{ padding: 10, borderRadius: 6, background: "#f0fdf4", color: "#166534", fontSize: 12 }}>{success}</div>
      )}

      {/* Config result */}
      {config && (
        <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
          <SectionTitle>Generated Project Config {config.source === "ai" ? "🤖" : "✏️"}</SectionTitle>

          {/* Summary */}
          {config.business_summary && (
            <div style={{ padding: "8px 12px", borderRadius: 6, background: "#f0f9ff",
              border: "1px solid #bae6fd", fontSize: 12, color: "#0c4a6e" }}>
              📌 {config.business_summary}
            </div>
          )}

          {/* Editables side by side */}
          <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
            {/* Pillars */}
            <div style={{ flex: "1 1 200px" }}>
              <label style={{ fontSize: 11, fontWeight: 700, color: "#374151", display: "block", marginBottom: 4 }}>
                🎯 Pillars ({config.pillars?.length || 0})
              </label>
              <textarea rows={5} value={(config.pillars || []).join(", ")}
                onChange={e => updatePillars(e.target.value)}
                style={{ width: "100%", padding: "6px 8px", borderRadius: 5, border: "1px solid #a5b4fc",
                  fontSize: 11, resize: "vertical", boxSizing: "border-box", fontFamily: "inherit" }} />
            </div>
            {/* Purchase intent */}
            <div style={{ flex: "1 1 200px" }}>
              <label style={{ fontSize: 11, fontWeight: 700, color: "#374151", display: "block", marginBottom: 4 }}>
                💰 Purchase Intent Keywords ({config.purchase_intent_keywords?.length || 0})
              </label>
              <textarea rows={5} value={(config.purchase_intent_keywords || []).join(", ")}
                onChange={e => updateIntentKws(e.target.value)}
                style={{ width: "100%", padding: "6px 8px", borderRadius: 5, border: "1px solid #6ee7b7",
                  fontSize: 11, resize: "vertical", boxSizing: "border-box", fontFamily: "inherit" }} />
            </div>
            {/* Supporting angles */}
            <div style={{ flex: "1 1 200px" }}>
              <label style={{ fontSize: 11, fontWeight: 700, color: "#374151", display: "block", marginBottom: 4 }}>
                🧩 Supporting Angles ({config.supporting_angles?.length || 0})
              </label>
              <textarea rows={5} value={(config.supporting_angles || []).join(", ")}
                onChange={e => updateAngles(e.target.value)}
                style={{ width: "100%", padding: "6px 8px", borderRadius: 5, border: "1px solid #fcd34d",
                  fontSize: 11, resize: "vertical", boxSizing: "border-box", fontFamily: "inherit" }} />
            </div>
          </div>

          {/* Synonyms */}
          {config.synonyms && Object.keys(config.synonyms).length > 0 && (
            <div>
              <label style={{ fontSize: 11, fontWeight: 700, color: "#374151", display: "block", marginBottom: 4 }}>
                🔄 Synonyms / Regional Names
              </label>
              <div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
                {Object.entries(config.synonyms).map(([pillar, syns]) =>
                  syns.length > 0 && (
                    <div key={pillar} style={{
                      padding: "4px 10px", borderRadius: 6, background: "#faf5ff",
                      border: "1px solid #e9d5ff", fontSize: 11
                    }}>
                      <strong style={{ color: "#7c3aed" }}>{pillar}</strong>
                      <span style={{ color: "#9ca3af" }}> → </span>
                      {syns.join(", ")}
                    </div>
                  )
                )}
              </div>
            </div>
          )}

          {/* Language examples */}
          {config.customer_language_examples?.length > 0 && (
            <div>
              <label style={{ fontSize: 11, fontWeight: 700, color: "#374151", display: "block", marginBottom: 4 }}>
                🗣 Example Customer Searches
              </label>
              <div style={{ display: "flex", gap: 5, flexWrap: "wrap" }}>
                {config.customer_language_examples.map((ex, i) => (
                  <span key={i} style={{
                    padding: "3px 9px", borderRadius: 8, border: "1px solid #e5e7eb",
                    background: "#f9fafb", fontSize: 11, color: "#374151"
                  }}>"{ex}"</span>
                ))}
              </div>
            </div>
          )}

          <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
            <Btn onClick={handleSaveManual} disabled={saving} color="green" size="sm">
              {saving ? "Saving…" : "💾 Save Changes"}
            </Btn>
            <Btn onClick={() => onReady?.()} color="blue" size="sm">
              ✓ Config Ready — Go to Sync →
            </Btn>
            {config.generated_at && (
              <span style={{ fontSize: 10, color: "#9ca3af" }}>
                Generated: {new Date(config.generated_at).toLocaleString()}
              </span>
            )}
          </div>
        </div>
      )}
    </div>
  )
}

/* ── Tab 1: Connect & Sync ───────────────────────────────────────────────── */

function Tab1Connect({ projectId, status, onRefreshStatus }) {
  const [sites, setSites] = useState([])
  const [loadingSites, setLoadingSites] = useState(false)
  const [syncing, setSyncing] = useState(false)
  const [syncDays, setSyncDays] = useState(90)
  const [syncResult, setSyncResult] = useState(null)
  const [error, setError] = useState(null)

  // Phase 3: API Key validation
  const [apiKey, setApiKey] = useState("")
  const [keyResult, setKeyResult] = useState(null)
  const [validating, setValidating] = useState(false)
  const [importing, setImporting] = useState(false)
  const [importResult, setImportResult] = useState(null)

  const handleValidateKey = useCallback(async () => {
    if (!apiKey.trim()) return
    setValidating(true); setKeyResult(null)
    try {
      const r = await gscApi.validateKey(apiKey.trim())
      setKeyResult(r)
    } catch (e) { setKeyResult({ valid: false, error: e.message }) }
    setValidating(false)
  }, [apiKey])

  const handleImportStages = useCallback(async () => {
    setImporting(true); setError(null)
    try {
      const r = await gscApi.importFromStages(projectId)
      setImportResult(r)
      onRefreshStatus()
    } catch (e) { setError(e.message) }
    setImporting(false)
  }, [projectId])

  const handleConnect = useCallback(async () => {
    setError(null)
    try {
      const { auth_url } = await gscApi.getAuthUrl(projectId)
      const popup = window.open(auth_url, "gsc_auth", "width=600,height=700,scrollbars=yes")
      const onMsg = (e) => {
        if (e.data?.type === "gsc_auth_success") {
          window.removeEventListener("message", onMsg)
          onRefreshStatus()
        }
        if (e.data?.type === "gsc_auth_error") {
          window.removeEventListener("message", onMsg)
          setError(`Auth failed: ${e.data.error}`)
        }
      }
      window.addEventListener("message", onMsg)
      // Fallback: poll every 2s in case popup messaging fails
      const poll = setInterval(() => {
        if (popup?.closed) { clearInterval(poll); onRefreshStatus() }
      }, 2000)
    } catch (e) {
      setError(e.message)
    }
  }, [projectId])

  const handleLoadSites = useCallback(async () => {
    setLoadingSites(true); setError(null)
    try {
      const { sites: s } = await gscApi.listSites(projectId)
      setSites(s || [])
    } catch (e) { setError(e.message) }
    setLoadingSites(false)
  }, [projectId])

  const handleSetSite = useCallback(async (url) => {
    try {
      await gscApi.setSite(projectId, url)
      onRefreshStatus()
    } catch (e) { setError(e.message) }
  }, [projectId])

  const handleSync = useCallback(async () => {
    setSyncing(true); setError(null); setSyncResult(null)
    try {
      const r = await gscApi.syncData(projectId, syncDays)
      setSyncResult(r)
      onRefreshStatus()
    } catch (e) { setError(e.message) }
    setSyncing(false)
  }, [projectId, syncDays])

  const handleDisconnect = useCallback(async () => {
    if (!confirm("Disconnect Google Search Console? Synced data will be kept.")) return
    try {
      await gscApi.disconnect(projectId)
      onRefreshStatus()
    } catch (e) { setError(e.message) }
  }, [projectId])

  const connected = status?.connected

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
      {/* Connection Card */}
      <div style={{
        padding: 16, borderRadius: 10, border: `2px solid ${connected ? "#10b981" : "#d1d5db"}`,
        background: connected ? "#f0fdf4" : "#fafafa",
      }}>
        <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 8 }}>
          <span style={{ fontSize: 28 }}>{connected ? "🟢" : "⚪"}</span>
          <div>
            <div style={{ fontWeight: 700, fontSize: 14 }}>
              {connected ? "Connected" : "Not Connected"}
            </div>
            {connected && status?.site_url && (
              <div style={{ fontSize: 11, color: "#6b7280" }}>{status.site_url}</div>
            )}
          </div>
          <div style={{ marginLeft: "auto", display: "flex", gap: 8 }}>
            {!connected && (
              <Btn onClick={handleConnect} color="blue" size="sm">🔗 Connect Google Search Console</Btn>
            )}
            {connected && (
              <Btn onClick={handleDisconnect} color="red" size="sm">Disconnect</Btn>
            )}
          </div>
        </div>
        {connected && (
          <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
            <MetricCard label="Raw Keywords" value={status?.raw_count?.toLocaleString()} color="#3b82f6" />
            <MetricCard label="Processed" value={status?.processed_count?.toLocaleString()} color="#10b981" />
            <MetricCard label="Top 100" value={status?.top100_count?.toLocaleString()} color="#f59e0b" />
            <MetricCard label="Pillars" value={status?.pillar_count} color="#8b5cf6" />
          </div>
        )}
      </div>

      {/* Site Selection */}
      {connected && (
        <div>
          <SectionTitle>Select Site</SectionTitle>
          <div style={{ display: "flex", gap: 8, alignItems: "center", marginBottom: 8 }}>
            <Btn onClick={handleLoadSites} disabled={loadingSites} color="gray" size="sm">
              {loadingSites ? "Loading..." : "📋 List My Sites"}
            </Btn>
            {status?.site_url && (
              <span style={{ fontSize: 12, color: "#10b981", fontWeight: 600 }}>
                ✓ Active: {status.site_url}
              </span>
            )}
          </div>
          {sites.length > 0 && (
            <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
              {sites.map((s, i) => (
                <div key={i} style={{
                  display: "flex", alignItems: "center", gap: 8, padding: "6px 10px",
                  borderRadius: 6, border: "1px solid #e5e7eb", background: "#fff", fontSize: 12,
                }}>
                  <span style={{ flex: 1 }}>{s.url}</span>
                  <span style={{ color: "#9ca3af", fontSize: 10 }}>{s.permission}</span>
                  <Btn onClick={() => handleSetSite(s.url)} color="blue" size="sm">Use This Site</Btn>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {/* Sync */}
      {connected && status?.site_url && (
        <div>
          <SectionTitle>Fetch GSC Data</SectionTitle>
          <p style={{ fontSize: 12, color: "#6b7280", margin: "0 0 8px" }}>
            Pulls all search queries from your site (1 API call — paginates internally up to 25,000 rows).
          </p>
          <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
            <select
              value={syncDays}
              onChange={(e) => setSyncDays(Number(e.target.value))}
              style={{ padding: "4px 8px", borderRadius: 5, border: "1px solid #d1d5db", fontSize: 12 }}
            >
              <option value={28}>Last 28 days</option>
              <option value={90}>Last 90 days</option>
              <option value={180}>Last 6 months</option>
            </select>
            <Btn onClick={handleSync} disabled={syncing} color="green">
              {syncing ? "⟳ Syncing..." : "⬇ Fetch Data"}
            </Btn>
          </div>
          {syncResult && (
            <div style={{ marginTop: 8, padding: "8px 12px", borderRadius: 6, background: "#f0fdf4", fontSize: 12, color: "#166534" }}>
              ✓ Fetched {syncResult.fetched?.toLocaleString()} keywords. Total in DB: {syncResult.total_in_db?.toLocaleString()}
            </div>
          )}
        </div>
      )}

      {!connected && (
        <>
          {/* API Key Validation */}
          <div style={{
            padding: 14, borderRadius: 8, background: "#f5f3ff", border: "1px solid #ddd6fe",
          }}>
            <div style={{ fontWeight: 700, fontSize: 13, color: "#5b21b6", marginBottom: 6 }}>
              🔑 Connect with API Key (Gemini)
            </div>
            <div style={{ fontSize: 11, color: "#6b7280", marginBottom: 8 }}>
              Validate your Google API key for AI-powered features (intent classification, cluster naming, intelligence analysis).
            </div>
            <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
              <input
                type="password"
                value={apiKey}
                onChange={e => setApiKey(e.target.value)}
                placeholder="AIzaSy..."
                style={{ flex: 1, padding: "6px 10px", borderRadius: 6, border: "1px solid #d1d5db", fontSize: 12, maxWidth: 380 }}
              />
              <Btn onClick={handleValidateKey} disabled={validating || !apiKey.trim()} color="blue" size="sm">
                {validating ? "⟳ Validating..." : "✓ Validate Key"}
              </Btn>
            </div>
            {keyResult && (
              <div style={{
                marginTop: 8, padding: "8px 12px", borderRadius: 6, fontSize: 12,
                background: keyResult.valid ? "#f0fdf4" : "#fef2f2",
                color: keyResult.valid ? "#166534" : "#991b1b",
                border: `1px solid ${keyResult.valid ? "#bbf7d0" : "#fecaca"}`,
              }}>
                {keyResult.valid ? (
                  <>✅ Key valid! {keyResult.model_count} models available ({keyResult.models?.slice(0, 3).join(", ")}...)</>
                ) : (
                  <>❌ {keyResult.error}{keyResult.hint && <div style={{ marginTop: 4, fontSize: 10 }}>💡 {keyResult.hint}</div>}</>
                )}
              </div>
            )}
          </div>

          {/* Import from Stages - alternative to GSC OAuth */}
          <div style={{
            padding: 14, borderRadius: 8, background: "#f0f9ff", border: "1px solid #bae6fd",
          }}>
            <div style={{ fontWeight: 700, fontSize: 13, color: "#0369a1", marginBottom: 6 }}>
              📥 Import from Previous Stages (No GSC Required)
            </div>
            <div style={{ fontSize: 11, color: "#6b7280", marginBottom: 8 }}>
              Pull keywords from Stage 1 (crawl) and Stage 2 (discovery) into the GSC engine for intelligence processing.
              This lets you use all GSC features without needing a live GSC connection.
            </div>
            <Btn onClick={handleImportStages} disabled={importing} color="green" size="sm">
              {importing ? "⟳ Importing..." : "📥 Import Stage Keywords"}
            </Btn>
            {importResult && (
              <div style={{
                marginTop: 8, padding: "8px 12px", borderRadius: 6, fontSize: 12,
                background: importResult.imported > 0 ? "#f0fdf4" : "#fef9c3",
                color: importResult.imported > 0 ? "#166534" : "#854d0e",
              }}>
                {importResult.imported > 0
                  ? `✅ Imported ${importResult.imported} keywords. Sources: ${Object.entries(importResult.sources || {}).filter(([,v]) => v > 0).map(([k,v]) => `${k}: ${v}`).join(", ")}`
                  : importResult.message || "No keywords found. Complete earlier stages first."}
              </div>
            )}
          </div>

          {/* Setup Instructions */}
          <div style={{
            padding: 14, borderRadius: 8, background: "#fefce8", border: "1px solid #fde68a", fontSize: 12,
          }}>
            <div style={{ fontWeight: 700, marginBottom: 4 }}>GSC OAuth Setup (Optional — for live data sync)</div>
            <ol style={{ margin: 0, paddingLeft: 18, lineHeight: 1.8 }}>
              <li>Add <code>GOOGLE_CLIENT_ID</code> and <code>GOOGLE_CLIENT_SECRET</code> to your <code>.env</code> file</li>
              <li>Set <code>GOOGLE_REDIRECT_URI=http://localhost:8000/api/gsc/auth/callback</code></li>
              <li>See <strong>GCP/GSC_OAUTH_SETUP.md</strong> for full setup guide</li>
            </ol>
          </div>
        </>
      )}

      {error && (
        <div style={{ padding: 10, borderRadius: 6, background: "#fee2e2", color: "#dc2626", fontSize: 12 }}>
          {error}
        </div>
      )}
    </div>
  )
}

/* ── Tab 2: Intelligence ─────────────────────────────────────────────────── */

function Tab2Intelligence({ projectId, profile, status, onRefreshStatus }) {
  const [processing, setProcessing] = useState(false)
  const [result, setResult] = useState(null)
  const [keywords, setKeywords] = useState([])
  const [pillarFilter, setPillarFilter] = useState("")
  const [intentFilter, setIntentFilter] = useState("")
  const [searchQ, setSearchQ] = useState("")
  const [sortBy, setSortBy] = useState("score")
  const [sortDir, setSortDir] = useState("desc")
  const [error, setError] = useState(null)
  const [loading, setLoading] = useState(false)
  const [page, setPage] = useState(0)
  const PAGE_SIZE = 50

  // Phase 3: AI Summary + Stage Data
  const [summary, setSummary] = useState(null)
  const [summaryLoading, setSummaryLoading] = useState(false)
  const [stageData, setStageData] = useState(null)
  const [importing, setImporting] = useState(false)

  useEffect(() => {
    if (status?.processed_count > 0) loadKeywords()
    loadSummary()
    loadStageData()
  }, [status])

  const loadSummary = useCallback(async () => {
    try {
      const r = await gscApi.getIntelligenceSummary(projectId)
      if (r.summary) setSummary(r.summary)
    } catch { /* silent */ }
  }, [projectId])

  const loadStageData = useCallback(async () => {
    try {
      const r = await gscApi.getStageData(projectId)
      setStageData(r)
    } catch { /* silent */ }
  }, [projectId])

  const handleGenerateSummary = useCallback(async () => {
    setSummaryLoading(true); setError(null)
    try {
      const r = await gscApi.generateIntelligenceSummary(projectId)
      if (r.summary) setSummary(r.summary)
    } catch (e) { setError(e.message) }
    setSummaryLoading(false)
  }, [projectId])

  const handleImportStages = useCallback(async () => {
    setImporting(true); setError(null)
    try {
      const r = await gscApi.importFromStages(projectId)
      setResult({ imported: r.imported, sources: r.sources })
      onRefreshStatus()
    } catch (e) { setError(e.message) }
    setImporting(false)
  }, [projectId])

  const loadKeywords = useCallback(async () => {
    setLoading(true)
    try {
      const { keywords: kws } = await gscApi.getKeywords(projectId)
      setKeywords(kws || [])
    } catch (e) { setError(e.message) }
    setLoading(false)
  }, [projectId])

  // Use AI recommended pillars if available, else profile pillars
  const aiPillars = summary?.recommended_pillars || []
  const profilePillars = profile?.pillar_keywords || profile?.pillars || []
  const activePillars = aiPillars.length > 0 ? aiPillars : profilePillars

  const handleProcess = useCallback(async () => {
    setProcessing(true); setError(null); setResult(null)
    try {
      const r = await gscApi.processKeywords(projectId, activePillars)
      setResult(r)
      onRefreshStatus()
      await loadKeywords()
    } catch (e) { setError(e.message) }
    setProcessing(false)
  }, [projectId, activePillars])

  const handleSort = (col) => {
    if (sortBy === col) setSortDir(d => d === "desc" ? "asc" : "desc")
    else { setSortBy(col); setSortDir("desc") }
    setPage(0)
  }

  const uniquePillars = [...new Set(keywords.map(k => k.pillar).filter(Boolean))]
  const uniqueIntents = [...new Set(keywords.map(k => k.intent).filter(Boolean))]

  const filtered = keywords
    .filter(k => !pillarFilter || k.pillar === pillarFilter)
    .filter(k => !intentFilter || k.intent === intentFilter)
    .filter(k => !searchQ || k.keyword?.toLowerCase().includes(searchQ.toLowerCase()))
    .sort((a, b) => {
      const v = (x) => (typeof x[sortBy] === "number" ? x[sortBy] : 0)
      return sortDir === "desc" ? v(b) - v(a) : v(a) - v(b)
    })

  const paginated = filtered.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE)
  const totalPages = Math.ceil(filtered.length / PAGE_SIZE)

  const SortHdr = ({ col, label }) => (
    <th
      onClick={() => handleSort(col)}
      style={{ cursor: "pointer", padding: "6px 8px", fontSize: 10, fontWeight: 700, color: "#6b7280", whiteSpace: "nowrap", background: "#f9fafb", userSelect: "none" }}
    >{label} {sortBy === col ? (sortDir === "desc" ? "▼" : "▲") : "⇅"}</th>
  )

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>

      {/* Stage Data Overview */}
      {stageData?.stats && (
        <div style={{
          padding: 14, borderRadius: 8, background: "#f0f9ff", border: "1px solid #bae6fd",
        }}>
          <div style={{ fontWeight: 700, fontSize: 13, marginBottom: 8, color: "#0369a1" }}>📊 Stage 1+2 Data Available</div>
          <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
            {stageData.stats.has_profile && (
              <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 10, background: "#dcfce7", color: "#166534" }}>
                ✅ Business Profile
              </span>
            )}
            {stageData.stats.manual_pillar_count > 0 && (
              <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 10, background: "#dbeafe", color: "#1e40af" }}>
                {stageData.stats.manual_pillar_count} Manual Pillars
              </span>
            )}
            {stageData.stats.product_count > 0 && (
              <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 10, background: "#fef9c3", color: "#854d0e" }}>
                {stageData.stats.product_count} Products
              </span>
            )}
            {stageData.stats.ki_keyword_count > 0 && (
              <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 10, background: "#dbeafe", color: "#1e40af" }}>
                {stageData.stats.ki_keyword_count} Crawled Keywords
              </span>
            )}
            {stageData.stats.universe_count > 0 && (
              <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 10, background: "#e0e7ff", color: "#3730a3" }}>
                {stageData.stats.universe_count} Universe Keywords
              </span>
            )}
            {stageData.stats.competitor_count > 0 && (
              <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 10, background: "#fce7f3", color: "#9d174d" }}>
                {stageData.stats.competitor_count} Competitors
              </span>
            )}
          </div>
          {/* Import button - if no raw GSC data yet */}
          {!status?.raw_count && (stageData.stats.ki_keyword_count > 0 || stageData.stats.universe_count > 0 || stageData.stats.product_count > 0) && (
            <div style={{ marginTop: 10 }}>
              <Btn onClick={handleImportStages} disabled={importing} color="blue">
                {importing ? "⟳ Importing..." : "📥 Import Stage 1+2 Keywords to GSC"}
              </Btn>
              <span style={{ fontSize: 10, color: "#6b7280", marginLeft: 8 }}>
                Pull all discovered keywords into GSC engine for classification
              </span>
            </div>
          )}
        </div>
      )}

      {/* AI Intelligence Summary */}
      <div style={{
        padding: 14, borderRadius: 8, border: "1px solid #e5e7eb",
        background: summary ? "#f5f3ff" : "#f9fafb",
      }}>
        <div style={{
          display: "flex", alignItems: "center", gap: 12, marginBottom: summary ? 12 : 0,
        }}>
          <div style={{ flex: 1 }}>
            <div style={{ fontWeight: 700, fontSize: 13, color: summary ? "#5b21b6" : "#374151" }}>
              🧠 AI Intelligence Analysis
            </div>
            <div style={{ fontSize: 11, color: "#6b7280" }}>
              {summary
                ? "AI analyzed your business data from previous stages"
                : "Generate AI analysis of your business, pillars, and keyword strategy"}
            </div>
          </div>
          <Btn onClick={handleGenerateSummary} disabled={summaryLoading} color="blue">
            {summaryLoading ? "⟳ Analyzing..." : summary ? "↻ Refresh Analysis" : "▶ Generate Analysis"}
          </Btn>
        </div>

        {summary && (
          <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
            {/* Business Summary */}
            {summary.business_summary && (
              <div style={{ fontSize: 12, color: "#374151", lineHeight: 1.5, padding: 10, background: "#fff", borderRadius: 6, border: "1px solid #e5e7eb" }}>
                {summary.business_summary}
              </div>
            )}

            {/* AI Recommended Pillars */}
            {summary.recommended_pillars?.length > 0 && (
              <div>
                <div style={{ fontSize: 11, fontWeight: 700, color: "#5b21b6", marginBottom: 4 }}>
                  🎯 AI Recommended Pillars (replaces product SKUs)
                </div>
                <div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>
                  {summary.recommended_pillars.map((p, i) => (
                    <span key={i} style={{
                      fontSize: 11, padding: "3px 10px", borderRadius: 10,
                      background: "#ede9fe", color: "#5b21b6", fontWeight: 600,
                    }}>{p}</span>
                  ))}
                </div>
              </div>
            )}

            {/* Pillar Analysis */}
            {summary.pillar_analysis?.length > 0 && (
              <div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
                {summary.pillar_analysis.map((p, i) => (
                  <div key={i} style={{
                    flex: "1 1 200px", padding: 10, borderRadius: 6,
                    border: "1px solid #e5e7eb", background: "#fff",
                  }}>
                    <div style={{ fontWeight: 700, fontSize: 12, marginBottom: 2 }}>{p.name}</div>
                    <span style={{
                      fontSize: 9, padding: "1px 6px", borderRadius: 8, fontWeight: 600,
                      background: p.opportunity === "high" ? "#dcfce7" : p.opportunity === "medium" ? "#fef9c3" : "#fee2e2",
                      color: p.opportunity === "high" ? "#166534" : p.opportunity === "medium" ? "#854d0e" : "#991b1b",
                    }}>{p.opportunity}</span>
                    <div style={{ fontSize: 10, color: "#6b7280", marginTop: 4 }}>{p.reason}</div>
                    {p.keyword_focus?.length > 0 && (
                      <div style={{ marginTop: 4, display: "flex", gap: 3, flexWrap: "wrap" }}>
                        {p.keyword_focus.slice(0, 5).map((k, j) => (
                          <span key={j} style={{ fontSize: 9, padding: "1px 5px", borderRadius: 6, background: "#f3f4f6" }}>{k}</span>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}

            {/* Intent Strategy */}
            {summary.intent_strategy && (
              <div style={{ padding: 10, borderRadius: 6, background: "#fff", border: "1px solid #e5e7eb" }}>
                <div style={{ fontSize: 11, fontWeight: 700, color: "#374151", marginBottom: 4 }}>
                  ⚡ Intent Strategy: <span style={{ color: "#8b5cf6" }}>{summary.intent_strategy.primary_intent}</span>
                </div>
                <div style={{ fontSize: 10, color: "#6b7280" }}>{summary.intent_strategy.reasoning}</div>
                {summary.intent_strategy.purchase_signals?.length > 0 && (
                  <div style={{ marginTop: 4, display: "flex", gap: 3, flexWrap: "wrap" }}>
                    <span style={{ fontSize: 9, fontWeight: 600 }}>Signals:</span>
                    {summary.intent_strategy.purchase_signals.slice(0, 8).map((s, i) => (
                      <span key={i} style={{ fontSize: 9, padding: "1px 5px", borderRadius: 6, background: "#fef9c3", color: "#854d0e" }}>{s}</span>
                    ))}
                  </div>
                )}
              </div>
            )}

            {/* Quick Recommendations */}
            {summary.quick_recommendations?.length > 0 && (
              <div style={{ padding: 10, borderRadius: 6, background: "#fff", border: "1px solid #e5e7eb" }}>
                <div style={{ fontSize: 11, fontWeight: 700, marginBottom: 4 }}>🔥 Quick Recommendations</div>
                {summary.quick_recommendations.map((r, i) => (
                  <div key={i} style={{ fontSize: 11, color: "#374151", padding: "2px 0" }}>• {r}</div>
                ))}
              </div>
            )}
          </div>
        )}
      </div>

      {/* Process button */}
      <div style={{
        padding: 14, borderRadius: 8, background: "#f9fafb", border: "1px solid #e5e7eb",
        display: "flex", alignItems: "center", gap: 12, flexWrap: "wrap",
      }}>
        <div style={{ flex: 1 }}>
          <div style={{ fontWeight: 700, fontSize: 13 }}>Run Intelligence Processing</div>
          <div style={{ fontSize: 11, color: "#6b7280" }}>
            Assigns keywords to pillars, classifies intent, and scores each keyword.
            {activePillars.length > 0 && ` Using ${activePillars.length} ${aiPillars.length > 0 ? 'AI-recommended' : 'profile'} pillars.`}
          </div>
          {activePillars.length > 0 && (
            <div style={{ marginTop: 4, display: "flex", gap: 4, flexWrap: "wrap" }}>
              {activePillars.map((p, i) => (
                <span key={i} style={{
                  fontSize: 10, padding: "1px 8px", borderRadius: 10,
                  background: aiPillars.length > 0 ? "#ede9fe" : "#dbeafe",
                  color: aiPillars.length > 0 ? "#5b21b6" : "#1e40af",
                }}>{p}</span>
              ))}
            </div>
          )}
        </div>
        <Btn onClick={handleProcess} disabled={processing || !status?.raw_count} color="blue">
          {processing ? "⟳ Processing..." : "▶ Run Classification + Scoring"}
        </Btn>
      </div>

      {result && (
        <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
          <MetricCard label="Processed" value={result.processed?.toLocaleString()} color="#3b82f6" />
          <MetricCard label="Top 100" value={result.top100?.toLocaleString()} color="#f59e0b" />
          <MetricCard label="Pillars Active" value={result.pillars} color="#10b981" />
        </div>
      )}

      {error && (
        <div style={{ padding: 10, borderRadius: 6, background: "#fee2e2", color: "#dc2626", fontSize: 12 }}>{error}</div>
      )}

      {/* Keyword table */}
      {keywords.length > 0 && (
        <div>
          <SectionTitle>Processed Keywords ({filtered.length})</SectionTitle>

          {/* Filters */}
          <div style={{ display: "flex", gap: 8, marginBottom: 10, flexWrap: "wrap", alignItems: "center" }}>
            <input
              value={searchQ} onChange={e => { setSearchQ(e.target.value); setPage(0) }}
              placeholder="Search keywords..."
              style={{ padding: "4px 8px", borderRadius: 5, border: "1px solid #d1d5db", fontSize: 12, width: 160 }}
            />
            {uniquePillars.length > 1 && (
              <select value={pillarFilter} onChange={e => { setPillarFilter(e.target.value); setPage(0) }}
                style={{ padding: "4px 8px", borderRadius: 5, border: "1px solid #d1d5db", fontSize: 12 }}>
                <option value="">All pillars</option>
                {uniquePillars.map(p => <option key={p} value={p}>{p}</option>)}
              </select>
            )}
            {uniqueIntents.length > 1 && (
              <select value={intentFilter} onChange={e => { setIntentFilter(e.target.value); setPage(0) }}
                style={{ padding: "4px 8px", borderRadius: 5, border: "1px solid #d1d5db", fontSize: 12 }}>
                <option value="">All intents</option>
                {uniqueIntents.map(i => <option key={i} value={i}>{i}</option>)}
              </select>
            )}
          </div>

          {loading ? (
            <p style={{ color: "#9ca3af", fontSize: 12 }}>Loading...</p>
          ) : (
            <>
              <div style={{ overflowX: "auto" }}>
                <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12 }}>
                  <thead>
                    <tr>
                      <th style={{ padding: "6px 8px", background: "#f9fafb", fontSize: 10, fontWeight: 700, color: "#6b7280", textAlign: "left" }}>Keyword</th>
                      <th style={{ padding: "6px 8px", background: "#f9fafb", fontSize: 10, fontWeight: 700, color: "#6b7280" }}>Pillar</th>
                      <SortHdr col="impressions" label="Impressions" />
                      <SortHdr col="clicks" label="Clicks" />
                      <SortHdr col="ctr" label="CTR" />
                      <SortHdr col="position" label="Pos." />
                      <SortHdr col="score" label="Score" />
                      <th style={{ padding: "6px 8px", background: "#f9fafb", fontSize: 10, fontWeight: 700, color: "#6b7280" }}>Intent</th>
                    </tr>
                  </thead>
                  <tbody>
                    {paginated.map((kw, i) => (
                      <tr key={i} style={{ borderBottom: "1px solid #f3f4f6", background: kw.top100 ? "#fffbeb" : "#fff" }}>
                        <td style={{ padding: "5px 8px" }}>
                          {kw.top100 && <span style={{ fontSize: 9, marginRight: 4 }}>★</span>}
                          {kw.keyword}
                          {kw.opportunity_score > 5 && (
                            <span title="Quick win: high impressions, poor rank" style={{ marginLeft: 6, fontSize: 9, color: "#f97316" }}>⚡</span>
                          )}
                        </td>
                        <td style={{ padding: "5px 8px", color: "#8b5cf6", fontSize: 10, fontWeight: 600 }}>
                          {kw.pillar}
                        </td>
                        <td style={{ padding: "5px 8px", textAlign: "right" }}>{(kw.impressions || 0).toLocaleString()}</td>
                        <td style={{ padding: "5px 8px", textAlign: "right" }}>{(kw.clicks || 0).toLocaleString()}</td>
                        <td style={{ padding: "5px 8px", textAlign: "right" }}>
                          {kw.ctr ? `${(kw.ctr * 100).toFixed(1)}%` : "—"}
                        </td>
                        <td style={{ padding: "5px 8px", textAlign: "right" }}>
                          {kw.position ? kw.position.toFixed(1) : "—"}
                        </td>
                        <td style={{ padding: "5px 8px", textAlign: "right", fontWeight: 700, color: kw.score > 50 ? "#10b981" : kw.score > 25 ? "#f59e0b" : "#6b7280" }}>
                          {kw.score?.toFixed(1)}
                        </td>
                        <td style={{ padding: "5px 8px" }}>
                          <IntentBadge intent={kw.intent || "informational"} />
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              {totalPages > 1 && (
                <div style={{ display: "flex", gap: 6, marginTop: 8, alignItems: "center" }}>
                  <button onClick={() => setPage(p => Math.max(0, p - 1))} disabled={page === 0}
                    style={{ padding: "3px 10px", fontSize: 11, border: "1px solid #d1d5db", borderRadius: 5, cursor: "pointer" }}>‹</button>
                  <span style={{ fontSize: 11, color: "#6b7280" }}>Page {page + 1} / {totalPages}</span>
                  <button onClick={() => setPage(p => Math.min(totalPages - 1, p + 1))} disabled={page >= totalPages - 1}
                    style={{ padding: "3px 10px", fontSize: 11, border: "1px solid #d1d5db", borderRadius: 5, cursor: "pointer" }}>›</button>
                </div>
              )}
            </>
          )}
        </div>
      )}
    </div>
  )
}

/* ── Tab 3: Strategy ─────────────────────────────────────────────────────── */

function Tab3Strategy({ projectId, status }) {
  const [top100, setTop100] = useState([])
  const [tree, setTree] = useState(null)
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState(null)
  const [view, setView] = useState("top100") // top100 | tree | opportunities

  useEffect(() => {
    if (status?.top100_count > 0) loadData()
  }, [status])

  const loadData = useCallback(async () => {
    setLoading(true)
    try {
      const [t100, treeData] = await Promise.all([
        gscApi.getTop100(projectId),
        gscApi.getTree(projectId),
      ])
      setTop100(t100.items || [])
      setTree(treeData.tree || null)
    } catch (e) { setError(e.message) }
    setLoading(false)
  }, [projectId])

  const quickWins = top100.filter(k => k.position > 10 && k.impressions > 200)
  const moneyKws = top100.filter(k => ["purchase", "wholesale"].includes(k.intent))
  const opportunities = top100.filter(k => k.opportunity_score > 5)

  const pillars = [...new Set(top100.map(k => k.pillar).filter(Boolean))]

  if (loading) return <p style={{ color: "#9ca3af", fontSize: 12 }}>Loading strategy data...</p>
  if (error) return <p style={{ color: "#dc2626", fontSize: 12 }}>{error}</p>
  if (top100.length === 0) return (
    <div style={{ padding: 16, borderRadius: 8, background: "#fafafa", border: "1px solid #e5e7eb", color: "#9ca3af", fontSize: 13 }}>
      No data yet. Complete Tab 2 (Intelligence Processing) first.
    </div>
  )

  const tabBtn = (v, label) => (
    <button onClick={() => setView(v)} style={{
      padding: "5px 14px", borderRadius: 6, fontSize: 12, fontWeight: 600, cursor: "pointer",
      border: view === v ? "2px solid #3b82f6" : "1px solid #d1d5db",
      background: view === v ? "#eff6ff" : "#fff",
      color: view === v ? "#1e40af" : "#6b7280",
    }}>{label}</button>
  )

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
      {/* Summary cards */}
      <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
        <MetricCard label="Top 100 Total" value={top100.length} color="#3b82f6" sub="across all pillars" />
        <MetricCard label="Money Keywords" value={moneyKws.length} color="#10b981" sub="purchase + wholesale" />
        <MetricCard label="Quick Wins" value={quickWins.length} color="#f59e0b" sub="pos > 10, imp > 200" />
        <MetricCard label="Opportunities" value={opportunities.length} color="#ef4444" sub="high impressions, low rank" />
      </div>

      {/* Strategy cards */}
      <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
        <div style={{ flex: "1 1 200px", padding: 12, borderRadius: 8, background: "#fefce8", border: "1px solid #fde68a" }}>
          <div style={{ fontWeight: 700, fontSize: 12, marginBottom: 6 }}>🔥 Quick Wins</div>
          <p style={{ fontSize: 11, color: "#6b7280", margin: "0 0 6px" }}>
            Already rank 11–50 with real demand. Small optimization can → top 10.
          </p>
          <div style={{ fontSize: 12, fontWeight: 600 }}>{quickWins.length} keywords</div>
        </div>
        <div style={{ flex: "1 1 200px", padding: 12, borderRadius: 8, background: "#f0fdf4", border: "1px solid #bbf7d0" }}>
          <div style={{ fontWeight: 700, fontSize: 12, marginBottom: 6 }}>💰 Money Keywords</div>
          <p style={{ fontSize: 11, color: "#6b7280", margin: "0 0 6px" }}>
            Purchase + wholesale intent. Optimize product pages for these first.
          </p>
          <div style={{ fontSize: 12, fontWeight: 600 }}>{moneyKws.length} keywords</div>
        </div>
        <div style={{ flex: "1 1 200px", padding: 12, borderRadius: 8, background: "#ede9fe", border: "1px solid #ddd6fe" }}>
          <div style={{ fontWeight: 700, fontSize: 12, marginBottom: 6 }}>📈 Content Gaps</div>
          <p style={{ fontSize: 11, color: "#6b7280", margin: "0 0 6px" }}>
            High impressions but low CTR → title/meta needs improvement.
          </p>
          <div style={{ fontSize: 12, fontWeight: 600 }}>
            {top100.filter(k => k.ctr < 0.02 && k.impressions > 200).length} keywords
          </div>
        </div>
      </div>

      {/* View toggle */}
      <div style={{ display: "flex", gap: 8 }}>
        {tabBtn("top100", `📋 Top 100 (${top100.length})`)}
        {tabBtn("opportunities", `⚡ Quick Wins (${quickWins.length})`)}
        {tabBtn("tree", "🌳 Tree View")}
      </div>

      {view === "top100" && (
        <div style={{ overflowX: "auto" }}>
          <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12 }}>
            <thead>
              <tr style={{ background: "#f9fafb" }}>
                <th style={{ padding: "6px 8px", textAlign: "left", fontSize: 10, color: "#6b7280" }}>#</th>
                <th style={{ padding: "6px 8px", textAlign: "left", fontSize: 10, color: "#6b7280" }}>Keyword</th>
                <th style={{ padding: "6px 8px", fontSize: 10, color: "#6b7280" }}>Pillar</th>
                <th style={{ padding: "6px 8px", fontSize: 10, color: "#6b7280" }}>Intent</th>
                <th style={{ padding: "6px 8px", textAlign: "right", fontSize: 10, color: "#6b7280" }}>Score</th>
                <th style={{ padding: "6px 8px", textAlign: "right", fontSize: 10, color: "#6b7280" }}>Impressions</th>
                <th style={{ padding: "6px 8px", textAlign: "right", fontSize: 10, color: "#6b7280" }}>Clicks</th>
                <th style={{ padding: "6px 8px", textAlign: "right", fontSize: 10, color: "#6b7280" }}>Pos.</th>
              </tr>
            </thead>
            <tbody>
              {top100.map((kw, i) => (
                <tr key={i} style={{ borderBottom: "1px solid #f3f4f6" }}>
                  <td style={{ padding: "4px 8px", color: "#9ca3af", fontSize: 10 }}>{i + 1}</td>
                  <td style={{ padding: "4px 8px" }}>
                    {kw.keyword}
                    {kw.opportunity_score > 5 && <span style={{ marginLeft: 5, fontSize: 9, color: "#f97316" }} title="Quick win">⚡</span>}
                  </td>
                  <td style={{ padding: "4px 8px", color: "#8b5cf6", fontSize: 10, fontWeight: 600 }}>{kw.pillar}</td>
                  <td style={{ padding: "4px 8px" }}><IntentBadge intent={kw.intent || "informational"} /></td>
                  <td style={{ padding: "4px 8px", textAlign: "right", fontWeight: 700, color: "#10b981" }}>{kw.score?.toFixed(1)}</td>
                  <td style={{ padding: "4px 8px", textAlign: "right" }}>{(kw.impressions || 0).toLocaleString()}</td>
                  <td style={{ padding: "4px 8px", textAlign: "right" }}>{(kw.clicks || 0).toLocaleString()}</td>
                  <td style={{ padding: "4px 8px", textAlign: "right" }}>{kw.position?.toFixed(1)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {view === "opportunities" && (
        <div>
          <p style={{ fontSize: 12, color: "#6b7280", marginBottom: 8 }}>
            Keywords with high impressions but ranking below position 10 — these are the easiest wins.
          </p>
          {quickWins.length === 0 ? (
            <p style={{ color: "#9ca3af", fontSize: 12 }}>No quick wins found. Try syncing more GSC data.</p>
          ) : (
            <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
              {quickWins.sort((a, b) => b.impressions - a.impressions).map((kw, i) => (
                <div key={i} style={{
                  padding: "8px 12px", borderRadius: 6, border: "1px solid #fde68a",
                  background: "#fffbeb", display: "flex", alignItems: "center", gap: 8, flexWrap: "wrap",
                }}>
                  <span style={{ flex: 1, fontSize: 12, fontWeight: 500 }}>{kw.keyword}</span>
                  <span style={{ fontSize: 10, color: "#8b5cf6", fontWeight: 600 }}>{kw.pillar}</span>
                  <span style={{ fontSize: 10, color: "#6b7280" }}>
                    pos: <strong style={{ color: "#ef4444" }}>{kw.position?.toFixed(1)}</strong>
                  </span>
                  <span style={{ fontSize: 10, color: "#6b7280" }}>
                    imp: <strong>{(kw.impressions || 0).toLocaleString()}</strong>
                  </span>
                  <IntentBadge intent={kw.intent} />
                  <span style={{ fontSize: 10, fontWeight: 700, color: "#10b981" }}>Score: {kw.score?.toFixed(1)}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {view === "tree" && tree && (
        <GscTree tree={tree} />
      )}
    </div>
  )
}

/* ── GSC Tree View ──────────────────────────────────────────────────────── */

function GscTree({ tree }) {
  const [openPillars, setOpenPillars] = useState({})
  const [openGroups, setOpenGroups] = useState({})
  const u = tree?.universe
  if (!u) return <p style={{ color: "#9ca3af", fontSize: 12 }}>No tree data.</p>

  const INTENT_ICON = { purchase: "💰", wholesale: "🏭", commercial: "⭐", informational: "📚", navigational: "🔗" }

  return (
    <div style={{ fontSize: 12 }}>
      <div style={{ fontWeight: 800, fontSize: 14, marginBottom: 12 }}>
        🌐 {u.name} — {u.total} keywords
      </div>
      {(u.pillars || []).map((pillar, pi) => {
        const pOpen = openPillars[pi]
        return (
          <div key={pi} style={{ marginBottom: 8, borderLeft: "3px solid #3b82f6", paddingLeft: 10 }}>
            <div
              onClick={() => setOpenPillars(s => ({ ...s, [pi]: !s[pi] }))}
              style={{ cursor: "pointer", fontWeight: 700, fontSize: 13, display: "flex", gap: 8, alignItems: "center", padding: "4px 0" }}
            >
              <span style={{ fontSize: 8 }}>{pOpen ? "▼" : "▶"}</span>
              🎯 {pillar.name}
              <span style={{ fontSize: 10, color: "#6b7280" }}>({pillar.total} kws, ★{pillar.top100})</span>
            </div>
            {pOpen && (
              <div style={{ paddingLeft: 14 }}>
                {(pillar.groups || []).map((grp, gi) => {
                  const gKey = `${pi}-${gi}`
                  const gOpen = openGroups[gKey]
                  return (
                    <div key={gi} style={{ marginBottom: 6 }}>
                      <div
                        onClick={() => setOpenGroups(s => ({ ...s, [gKey]: !s[gKey] }))}
                        style={{ cursor: "pointer", display: "flex", gap: 6, alignItems: "center", padding: "3px 0" }}
                      >
                        <span style={{ fontSize: 8 }}>{gOpen ? "▼" : "▶"}</span>
                        <IntentBadge intent={grp.intent} />
                        <span style={{ color: "#374151" }}>{grp.name}</span>
                        <span style={{ fontSize: 10, color: "#9ca3af" }}>({grp.count})</span>
                      </div>
                      {gOpen && (
                        <div style={{ paddingLeft: 16 }}>
                          {(grp.keywords || []).slice(0, 20).map((kw, ki) => (
                            <div key={ki} style={{
                              padding: "2px 0", display: "flex", gap: 8, alignItems: "center",
                              opacity: kw.top100 ? 1 : 0.6, borderBottom: "1px solid #f9fafb",
                            }}>
                              <span style={{ fontSize: 10, color: "#f59e0b" }}>{kw.top100 ? "★" : "·"}</span>
                              <span style={{ flex: 1 }}>{kw.keyword}</span>
                              <span style={{ color: "#9ca3af", fontSize: 10 }}>
                                imp:{kw.impressions?.toLocaleString()} pos:{kw.position?.toFixed(1)}
                              </span>
                              <span style={{ fontWeight: 700, color: "#10b981", fontSize: 10 }}>{kw.score?.toFixed(1)}</span>
                            </div>
                          ))}
                          {(grp.keywords || []).length > 20 && (
                            <div style={{ fontSize: 10, color: "#9ca3af", padding: "4px 0" }}>
                              ... and {grp.keywords.length - 20} more
                            </div>
                          )}
                        </div>
                      )}
                    </div>
                  )
                })}
              </div>
            )}
          </div>
        )
      })}
    </div>
  )
}

/* ── Main PhaseGSC Component ─────────────────────────────────────────────── */

/* ── Tab 4: Phase 2 Intelligence Dashboard ──────────────────────────────── */

function Tab4IntelligenceDashboard({ projectId, status }) {
  const [running, setRunning] = useState(false)
  const [pipelineResult, setPipelineResult] = useState(null)
  const [error, setError] = useState(null)

  const [view, setView] = useState("overview") // overview | clusters | graph | insights
  const [clusters, setClusters] = useState(null)
  const [graphData, setGraphData] = useState(null)
  const [insights, setInsights] = useState(null)
  const [authority, setAuthority] = useState(null)
  const [selectedNode, setSelectedNode] = useState(null)
  const [dataLoaded, setDataLoaded] = useState(false)

  useEffect(() => {
    if (status?.processed_count > 0) loadExistingData()
  }, [status])

  const loadExistingData = useCallback(async () => {
    try {
      const [c, g, ins, auth] = await Promise.all([
        gscApi.getClusters(projectId),
        gscApi.getGraph(projectId),
        gscApi.getInsights(projectId),
        gscApi.getAuthority(projectId),
      ])
      if (c.count > 0) setClusters(c.clusters)
      if (g.graph?.nodes?.length > 0) setGraphData(g.graph)
      if (Object.keys(ins.insights || {}).length > 0) setInsights(ins.insights)
      if (Object.keys(auth.authority || {}).length > 0) setAuthority(auth.authority)
      setDataLoaded(true)
    } catch { /* silent */ }
  }, [projectId])

  const handleRunPipeline = useCallback(async () => {
    setRunning(true); setError(null); setPipelineResult(null)
    try {
      const r = await gscApi.runIntelligence(projectId)
      setPipelineResult(r)
      await loadExistingData()
    } catch (e) { setError(e.message) }
    setRunning(false)
  }, [projectId])

  const tabBtn = (v, label) => (
    <button onClick={() => setView(v)} style={{
      padding: "5px 14px", borderRadius: 6, fontSize: 12, fontWeight: 600, cursor: "pointer",
      border: view === v ? "2px solid #8b5cf6" : "1px solid #d1d5db",
      background: view === v ? "#f5f3ff" : "#fff", color: view === v ? "#5b21b6" : "#6b7280",
    }}>{label}</button>
  )

  const hasData = clusters || graphData || insights

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
      {/* Pipeline runner */}
      <div style={{
        padding: 14, borderRadius: 8, background: "#f5f3ff", border: "1px solid #ddd6fe",
        display: "flex", alignItems: "center", gap: 12, flexWrap: "wrap",
      }}>
        <div style={{ flex: 1 }}>
          <div style={{ fontWeight: 700, fontSize: 13, color: "#5b21b6" }}>🧠 Phase 2 Intelligence Pipeline</div>
          <div style={{ fontSize: 11, color: "#6b7280" }}>
            Embeddings → AI Intent → HDBSCAN Clustering → Graph → Scoring v2 → Insights
          </div>
        </div>
        <Btn onClick={handleRunPipeline} disabled={running || !status?.processed_count} color="blue">
          {running ? "⟳ Running Pipeline..." : "▶ Run Intelligence"}
        </Btn>
      </div>

      {pipelineResult && (
        <div style={{ padding: 12, borderRadius: 8, background: "#f0fdf4", border: "1px solid #bbf7d0", fontSize: 12 }}>
          <div style={{ fontWeight: 700, marginBottom: 6 }}>✅ Pipeline Complete ({pipelineResult.total_time}s)</div>
          <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
            {Object.entries(pipelineResult.steps || {}).map(([step, data]) => (
              <span key={step} style={{ padding: "2px 8px", background: "#dcfce7", borderRadius: 6, fontSize: 10, fontWeight: 600 }}>
                {step}: {data.time}s
              </span>
            ))}
          </div>
        </div>
      )}

      {error && (
        <div style={{ padding: 10, borderRadius: 6, background: "#fee2e2", color: "#dc2626", fontSize: 12 }}>{error}</div>
      )}

      {/* Authority cards */}
      {authority && Object.keys(authority).length > 0 && (
        <div>
          <SectionTitle>Pillar Authority</SectionTitle>
          <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
            {Object.entries(authority).map(([pillar, data]) => (
              <div key={pillar} style={{
                padding: "10px 14px", borderRadius: 8, border: "1px solid #e5e7eb", background: "#fff",
                minWidth: 120, flex: "1 1 120px",
              }}>
                <div style={{ fontWeight: 700, fontSize: 12, marginBottom: 4 }}>{pillar}</div>
                <div style={{
                  fontSize: 22, fontWeight: 800,
                  color: data.authority_score >= 60 ? "#10b981" : data.authority_score >= 30 ? "#f59e0b" : "#ef4444",
                }}>{data.authority_score}</div>
                <div style={{ fontSize: 10, color: "#6b7280" }}>
                  {data.status} · {data.coverage} kws · {data.cluster_depth} clusters
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Sub-navigation */}
      {hasData && (
        <>
          <div style={{ display: "flex", gap: 8 }}>
            {tabBtn("overview", "📊 Overview")}
            {clusters && tabBtn("clusters", `🧩 Clusters (${Object.keys(clusters).length})`)}
            {graphData && tabBtn("graph", `🌐 Graph (${graphData.nodes?.length || 0})`)}
            {insights && tabBtn("insights", "🔥 Insights")}
          </div>

          {/* Overview */}
          {view === "overview" && insights && (
            <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
              <MetricCard label="Quick Wins" value={insights.quick_wins?.items?.length || 0} color="#f59e0b" sub="position 5-20, high impressions" />
              <MetricCard label="Money Keywords" value={insights.money_keywords?.items?.length || 0} color="#10b981" sub="transactional + demand" />
              <MetricCard label="Content Gaps" value={insights.content_gaps?.items?.length || 0} color="#ef4444" sub="clusters without purchase" />
              <MetricCard label="Link Suggestions" value={insights.linking?.items?.length || 0} color="#8b5cf6" sub="supporting → purchase" />
              <MetricCard label="Opportunities" value={insights.opportunities?.items?.length || 0} color="#f97316" sub="rank > 20, high impressions" />
            </div>
          )}

          {/* Clusters */}
          {view === "clusters" && clusters && (
            <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
              {Object.entries(clusters).map(([name, kws]) => (
                <div key={name} style={{ padding: 12, borderRadius: 8, border: "1px solid #e5e7eb", background: "#fafafa" }}>
                  <div style={{ fontWeight: 700, fontSize: 13, marginBottom: 6 }}>
                    🧩 {name} <span style={{ fontWeight: 400, fontSize: 11, color: "#6b7280" }}>({kws.length} keywords)</span>
                  </div>
                  <div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>
                    {kws.slice(0, 20).map((k, i) => (
                      <span key={i} style={{
                        padding: "2px 8px", borderRadius: 10, fontSize: 10, background: "#ede9fe", color: "#5b21b6",
                      }}>{k.keyword}</span>
                    ))}
                    {kws.length > 20 && (
                      <span style={{ fontSize: 10, color: "#9ca3af", padding: "2px 4px" }}>+{kws.length - 20} more</span>
                    )}
                  </div>
                  {kws[0]?.pillar && (
                    <div style={{ marginTop: 4, fontSize: 10, color: "#6b7280" }}>Pillar: {kws[0].pillar}</div>
                  )}
                </div>
              ))}
            </div>
          )}

          {/* Graph */}
          {view === "graph" && graphData && (
            <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
              <div style={{ flex: "1 1 400px", border: "1px solid #e5e7eb", borderRadius: 8, overflow: "hidden", background: "#fff" }}>
                <KeywordGraph
                  data={graphData}
                  width={600}
                  height={500}
                  onNodeClick={(node) => setSelectedNode(node)}
                />
              </div>
              {selectedNode && (
                <div style={{ flex: "0 0 250px", padding: 12, borderRadius: 8, border: "1px solid #e5e7eb", background: "#fafafa" }}>
                  <div style={{ fontWeight: 700, fontSize: 14, marginBottom: 8 }}>{selectedNode.id}</div>
                  <div style={{ fontSize: 12, color: "#6b7280", marginBottom: 4 }}>
                    Pillar: <strong style={{ color: "#8b5cf6" }}>{selectedNode.group || "—"}</strong>
                  </div>
                  <div style={{ fontSize: 12, color: "#6b7280", marginBottom: 4 }}>
                    Intent: <strong>{selectedNode.intent || "—"}</strong>
                  </div>
                  <div style={{ fontSize: 12, color: "#6b7280", marginBottom: 4 }}>
                    Score: <strong style={{ color: "#10b981" }}>{selectedNode.score || "—"}</strong>
                  </div>
                  {selectedNode.top100 && (
                    <span style={{ fontSize: 10, padding: "1px 8px", borderRadius: 10, background: "#fef9c3", color: "#854d0e", fontWeight: 600 }}>★ Top 100</span>
                  )}
                </div>
              )}
              <div style={{ fontSize: 10, color: "#9ca3af", width: "100%" }}>
                <strong>Legend:</strong>
                <span style={{ marginLeft: 8 }}>🔴 Purchase</span>
                <span style={{ marginLeft: 8 }}>🟡 Commercial</span>
                <span style={{ marginLeft: 8 }}>⚫ Informational</span>
                <span style={{ marginLeft: 8 }}>🔵 Navigational</span>
              </div>
            </div>
          )}

          {/* Insights */}
          {view === "insights" && insights && (
            <IntelligenceInsights insights={insights} />
          )}
        </>
      )}

      {!hasData && !running && status?.processed_count > 0 && (
        <div style={{ padding: 16, borderRadius: 8, background: "#fafafa", border: "1px solid #e5e7eb", color: "#6b7280", fontSize: 13 }}>
          Click "Run Intelligence" to generate clusters, graph, and insights from your processed keywords.
        </div>
      )}
    </div>
  )
}

function IntelligenceInsights({ insights }) {
  const [section, setSection] = useState("quick_wins")

  const secBtn = (s, label) => (
    <button onClick={() => setSection(s)} style={{
      padding: "4px 12px", borderRadius: 6, fontSize: 11, fontWeight: 600, cursor: "pointer",
      border: section === s ? "2px solid #f59e0b" : "1px solid #d1d5db",
      background: section === s ? "#fffbeb" : "#fff", color: section === s ? "#92400e" : "#6b7280",
    }}>{label}</button>
  )

  const quickWins = insights?.quick_wins?.items || []
  const moneyKws = insights?.money_keywords?.items || []
  const gaps = insights?.content_gaps?.items || []
  const links = insights?.linking?.items || []
  const opps = insights?.opportunities?.items || []

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
      <div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
        {secBtn("quick_wins", `🔥 Quick Wins (${quickWins.length})`)}
        {secBtn("money", `💰 Money (${moneyKws.length})`)}
        {secBtn("gaps", `📉 Gaps (${gaps.length})`)}
        {secBtn("linking", `🔗 Links (${links.length})`)}
        {secBtn("opportunities", `⚡ Opportunities (${opps.length})`)}
      </div>

      {section === "quick_wins" && (
        <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
          {quickWins.slice(0, 30).map((kw, i) => (
            <div key={i} style={{
              padding: "6px 10px", borderRadius: 6, border: "1px solid #fde68a", background: "#fffbeb",
              display: "flex", gap: 8, alignItems: "center", fontSize: 12,
            }}>
              <span style={{ flex: 1, fontWeight: 500 }}>{kw.keyword}</span>
              <span style={{ fontSize: 10, color: "#8b5cf6" }}>{kw.pillar}</span>
              <span style={{ fontSize: 10 }}>pos: <strong style={{ color: "#ef4444" }}>{kw.position}</strong></span>
              <span style={{ fontSize: 10 }}>imp: <strong>{kw.impressions?.toLocaleString()}</strong></span>
              <span style={{ fontSize: 10, fontWeight: 700, color: "#10b981" }}>potential: {kw.potential}</span>
            </div>
          ))}
          {quickWins.length === 0 && <p style={{ color: "#9ca3af", fontSize: 12 }}>No quick wins found.</p>}
        </div>
      )}

      {section === "money" && (
        <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
          {moneyKws.slice(0, 30).map((kw, i) => (
            <div key={i} style={{
              padding: "6px 10px", borderRadius: 6, border: "1px solid #bbf7d0", background: "#f0fdf4",
              display: "flex", gap: 8, alignItems: "center", fontSize: 12,
            }}>
              <span style={{ flex: 1, fontWeight: 500 }}>💰 {kw.keyword}</span>
              <span style={{ fontSize: 10, color: "#8b5cf6" }}>{kw.pillar}</span>
              <IntentBadge intent={kw.intent} />
              <span style={{ fontSize: 10 }}>imp: {kw.impressions?.toLocaleString()}</span>
              <span style={{ fontSize: 10, fontWeight: 700, color: "#10b981" }}>{kw.score?.toFixed(1)}</span>
            </div>
          ))}
          {moneyKws.length === 0 && <p style={{ color: "#9ca3af", fontSize: 12 }}>No money keywords found.</p>}
        </div>
      )}

      {section === "gaps" && (
        <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
          {gaps.map((gap, i) => (
            <div key={i} style={{
              padding: "8px 12px", borderRadius: 8, border: "1px solid #fecaca", background: "#fef2f2",
            }}>
              <div style={{ fontWeight: 700, fontSize: 12, marginBottom: 4 }}>📉 {gap.cluster}</div>
              <div style={{ fontSize: 11, color: "#6b7280", marginBottom: 4 }}>{gap.suggestion}</div>
              <div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>
                {gap.sample_keywords?.map((k, j) => (
                  <span key={j} style={{ fontSize: 10, padding: "1px 6px", borderRadius: 8, background: "#fee2e2" }}>{k}</span>
                ))}
              </div>
            </div>
          ))}
          {gaps.length === 0 && <p style={{ color: "#9ca3af", fontSize: 12 }}>No content gaps detected.</p>}
        </div>
      )}

      {section === "linking" && (
        <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
          {links.slice(0, 30).map((lnk, i) => (
            <div key={i} style={{
              padding: "6px 10px", borderRadius: 6, border: "1px solid #ddd6fe", background: "#f5f3ff",
              display: "flex", gap: 6, alignItems: "center", fontSize: 12,
            }}>
              <span style={{ flex: 1 }}>{lnk.from_keyword}</span>
              <span style={{ color: "#6b7280" }}>→</span>
              <span style={{ flex: 1, fontWeight: 600, color: "#10b981" }}>{lnk.to_keyword}</span>
              <span style={{ fontSize: 10, color: "#8b5cf6" }}>{lnk.pillar}</span>
            </div>
          ))}
          {links.length === 0 && <p style={{ color: "#9ca3af", fontSize: 12 }}>No linking suggestions yet.</p>}
        </div>
      )}

      {section === "opportunities" && (
        <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
          {opps.slice(0, 20).map((kw, i) => (
            <div key={i} style={{
              padding: "6px 10px", borderRadius: 6, border: "1px solid #fed7aa", background: "#fff7ed",
              display: "flex", gap: 8, alignItems: "center", fontSize: 12,
            }}>
              <span style={{ flex: 1, fontWeight: 500 }}>⚡ {kw.keyword}</span>
              <span style={{ fontSize: 10, color: "#8b5cf6" }}>{kw.pillar}</span>
              <span style={{ fontSize: 10 }}>pos: <strong style={{ color: "#ef4444" }}>{kw.position}</strong></span>
              <span style={{ fontSize: 10 }}>imp: <strong>{kw.impressions?.toLocaleString()}</strong></span>
            </div>
          ))}
          {opps.length === 0 && <p style={{ color: "#9ca3af", fontSize: 12 }}>No opportunities found.</p>}
        </div>
      )}
    </div>
  )
}

export default function PhaseGSC({ projectId, sessionId, onComplete }) {
  const { profile, setActivePhase } = useKw2Store()
  const [activeTab, setActiveTab] = useState(0)
  const [status, setStatus] = useState(null)
  const [statusLoading, setStatusLoading] = useState(true)

  const refreshStatus = useCallback(async () => {
    try {
      const s = await gscApi.getStatus(projectId)
      setStatus(s)
    } catch { /* silent */ }
    setStatusLoading(false)
  }, [projectId])

  useEffect(() => { refreshStatus() }, [projectId])

  const tabs = [
    { n: 0, label: "0. AI Config",      icon: "🧠" },
    { n: 1, label: "1. Connect & Sync", icon: "🔗" },
    { n: 2, label: "2. Intelligence",   icon: "⚡" },
    { n: 3, label: "3. Strategy",       icon: "📊" },
    { n: 4, label: "4. Phase 2 Intel",  icon: "🧠" },
  ]

  const tabStyle = (n) => ({
    padding: "6px 16px", borderRadius: 6, fontSize: 12, fontWeight: activeTab === n ? 700 : 400,
    border: activeTab === n ? "2px solid #3b82f6" : "1px solid #e5e7eb",
    background: activeTab === n ? "#eff6ff" : "#fff",
    color: activeTab === n ? "#1e40af" : "#6b7280",
    cursor: "pointer",
  })

  if (statusLoading) {
    return (
      <div style={{ padding: 24, borderRadius: 10, border: "1px solid #e5e7eb", background: "#fff" }}>
        <p style={{ color: "#9ca3af" }}>Loading GSC status...</p>
      </div>
    )
  }

  return (
    <div style={{ borderRadius: 10, border: "1px solid #e5e7eb", background: "#fff", overflow: "hidden" }}>
      {/* Header */}
      <div style={{
        padding: "14px 18px", borderBottom: "1px solid #e5e7eb",
        background: "linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%)",
        display: "flex", justifyContent: "space-between", alignItems: "center",
      }}>
        <div>
          <div style={{ color: "#fff", fontWeight: 800, fontSize: 16 }}>
            🔍 Google Search Console Engine
          </div>
          <div style={{ color: "#93c5fd", fontSize: 11 }}>
            AI config → Real GSC demand → Filtered per pillar → Business-prioritized top 100
          </div>
        </div>
        <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
          <div style={{
            padding: "3px 10px", borderRadius: 10, fontSize: 10, fontWeight: 700,
            background: status?.connected ? "#10b981" : "#6b7280", color: "#fff",
          }}>
            {status?.connected ? "🟢 Connected" : "⚪ Not Connected"}
          </div>
          {status?.processed_count > 0 && (
            <button onClick={onComplete} style={{
              padding: "4px 12px", borderRadius: 6, fontSize: 11, fontWeight: 700,
              background: "#10b981", color: "#fff", border: "none", cursor: "pointer",
            }}>
              Continue to Generate →
            </button>
          )}
        </div>
      </div>

      {/* Tab bar */}
      <div style={{ display: "flex", gap: 6, padding: "10px 16px", borderBottom: "1px solid #f3f4f6", background: "#fafafa", flexWrap: "wrap" }}>
        {tabs.map(t => (
          <button key={t.n} onClick={() => setActiveTab(t.n)} style={tabStyle(t.n)}>
            {t.icon} {t.label}
          </button>
        ))}
      </div>

      {/* Tab content */}
      <div style={{ padding: 18 }}>
        {activeTab === 0 && (
          <Tab0Intelligence
            projectId={projectId}
            onReady={() => setActiveTab(1)}
          />
        )}
        {activeTab === 1 && (
          <Tab1Connect projectId={projectId} status={status} onRefreshStatus={refreshStatus} />
        )}
        {activeTab === 2 && (
          <Tab2Intelligence projectId={projectId} profile={profile} status={status} onRefreshStatus={refreshStatus} />
        )}
        {activeTab === 3 && (
          <Tab3Strategy projectId={projectId} status={status} />
        )}
        {activeTab === 4 && (
          <Tab4IntelligenceDashboard projectId={projectId} status={status} />
        )}
      </div>
    </div>
  )
}
