# AnnaSEO — Environment Variables
# Copy to .env and fill in your values
# Never commit .env to git

# ── Required: AI APIs ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
GEMINI_API_KEY=AIzaSy-xxxx
GROQ_API_KEY=gsk_xxxx

# ── Local AI (Ollama) ─────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:7b
CLAUDE_MODEL=claude-sonnet-4-6

# ── App ───────────────────────────────────────────────────────────────────────
ANNASEO_DB=./annaseo.db
ENGINES_DIR=./
VERSIONS_DIR=./rsd_versions
JWT_SECRET=change-this-to-a-random-secret-in-production
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here
FRONTEND_URL=http://localhost:5173

# ── Publishing ────────────────────────────────────────────────────────────────
WP_URL=https://yoursite.com
WP_USER=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_TOKEN=shpat_xxxx

# ── Google Search Console ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/api/gsc/callback

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# GA4_MEASUREMENT_ID=G-xxxx
# GA4_PROPERTY_ID=xxxx

# ── Content thresholds ────────────────────────────────────────────────────────
PUBLISH_THRESHOLD=75
MAX_AUTO_REVISIONS=2
GEMINI_RATE_LIMIT_SECONDS=4.0
